# Supabase project credentials
# Get these from https://supabase.com/dashboard/project/_/settings/api
# Or, if running locally with the Supabase CLI, run `supabase status` to see them.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL for OpenGraph metadata + email confirmation redirects
# In production set this to https://your-domain. Defaults to http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production admission gate for a personal archive.
# Preferred: one owner email. Production/Vercel production fails closed when
# both ARCHIVE_OWNER_EMAIL and ALLOWED_SIGNUP_EMAIL_DOMAINS are empty.
ARCHIVE_OWNER_EMAIL=

# Optional fallback for broader deployments.
# Supports exact domains and wildcard subdomains, e.g. example.com,*.example.com
ALLOWED_SIGNUP_EMAIL_DOMAINS=
