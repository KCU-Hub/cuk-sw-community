{
  "name": "heznpc-archive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prestart": "node scripts/check-production-env.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "db:start": "supabase start --exclude vector --ignore-health-check",
    "db:reset": "supabase db reset --db-url postgresql://postgres:postgres@127.0.0.1:54322/postgres --no-seed",
    "check:production-env": "node scripts/check-production-env.mjs",
    "types:gen:local": "node scripts/generate-supabase-types.mjs --db-url postgresql://postgres:postgres@127.0.0.1:54322/postgres --schema public",
    "types:gen:remote": "node scripts/generate-supabase-types.mjs --project-id \"$SUPABASE_PROJECT_ID\" --schema public"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "highlight.js": "^11.11.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "^16.2.9",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "supabase": "^2.107.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6",
    "unified": "^11.0.5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "postcss": "8.5.15"
  }
}
